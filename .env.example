# Used to sign the web UI's session cookie and salt the login password
# hash. Set this to a long random value before deploying publicly.
SECRET_KEY=dev-secret-key

GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
TAVILY_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=research-os
GITHUB_TOKEN=
OPENROUTER_API_KEY=

# Written automatically by the web UI (web/) on first run -- no need to
# set these by hand. Leaving them blank triggers the account-creation
# screen the first time you open the app.
WEB_USERNAME=
WEB_PASSWORD_HASH=