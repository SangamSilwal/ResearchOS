# Signs JWTs, salts encrypted API keys (web/crypto.py), and signs the
# transient OAuth-handshake session cookie. Set this to a long random
# value before deploying publicly -- rotating it later invalidates all
# issued JWTs AND makes previously-encrypted user API keys undecryptable.
SECRET_KEY=dev-secret-key

# ---- platform-level provider keys ----------------------------------
# GROQ_API_KEY is the important one: every agent defaults to Groq (see
# web/model_defaults.py), so this key is what powers a brand new
# account with zero setup. The others are only used if you, the
# operator, want the platform itself to fall back to them too --
# otherwise each user brings their own via the API (see README).
GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

TAVILY_API_KEY=
GITHUB_TOKEN=

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=research-os

# ---- database (Postgres via Supabase) -------------------------------
# Supabase dashboard -> Project Settings -> Database -> Connection
# string -> "URI". Copy it, then change the "postgresql://" prefix to
# "postgresql+asyncpg://" (SQLAlchemy's async Postgres driver).
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ---- OAuth (Google + GitHub login) -----------------------------------
# Google: console.cloud.google.com -> APIs & Services -> Credentials
# GitHub: github.com/settings/developers -> OAuth Apps
# Authorized redirect URIs to register on both:
#   {OAUTH_REDIRECT_BASE_URL}/auth/google/callback
#   {OAUTH_REDIRECT_BASE_URL}/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# Where to send the browser after login, with the JWT as ?token=...
# Leave blank until you have a frontend -- the callback then returns the
# token as JSON instead, which is fine for testing via curl/Swagger.
FRONTEND_URL=
