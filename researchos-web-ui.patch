+{% if result.status == "error" %}
+  <p class="flash flash-error">Run failed: {{ result.error }}</p>
+{% else %}
+  {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}
+
+  {% if result.competition %}
+  <p><strong>Architecture winner:</strong> {{ result.competition.winner }} &mdash; {{ result.competition.justification }}</p>
+  {% endif %}
+
+  <p><strong>Tasks:</strong>
+    {% for status, count in result.tasks_by_status.items() %}{{ status }}: {{ count }}&nbsp; {% endfor %}
+  </p>
+
+  {% if result.files_written %}
+  <p><strong>Files written:</strong></p>
+  <ul>{% for f in result.files_written %}<li><code>{{ f }}</code></li>{% endfor %}</ul>
+  {% endif %}
+
+  {% if result.flagged %}
+  <p><strong>Flagged for human review:</strong></p>
+  <ul>
+    {% for t in result.flagged %}
+    <li><code>{{ t.output_path }}</code> &mdash; {{ t.title }}
+      {% if t.feedback %}<br><span class="muted">{{ t.feedback }}</span>{% endif %}
+    </li>
+    {% endfor %}
+  </ul>
+  {% endif %}
+{% endif %}
