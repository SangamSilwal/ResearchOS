+{% extends "base.html" %}
+{% block title %}Dashboard · ResearchOS{% endblock %}
+{% block content %}
+<h1>New goal</h1>
+<form method="post" action="/runs" class="run-form">
+  <label>What should ResearchOS build or research?
+    <textarea name="goal" rows="3" required placeholder="e.g. Build a REST API with FastAPI and PostgreSQL for a bookmarking app"></textarea>
+  </label>
+  <label>Project ID <span class="hint">(optional -- reuse one to resume/checkpoint a previous run)</span>
+    <input type="text" name="project_id" placeholder="leave blank to auto-generate">
+  </label>
+  <button type="submit">Run</button>
+</form>
+
+<h2>Recent runs</h2>
+{% if recent_runs %}
+<table class="runs-table">
+  <thead><tr><th>Goal</th><th>Tasks</th><th>Files</th><th>Flagged</th></tr></thead>
+  <tbody>
+    {% for r in recent_runs %}
+    <tr>
+      <td><a href="/run/{{ r.project_id }}">{{ r.goal }}</a></td>
+      <td>{% for status, count in r.task_summary.items() %}{{ status }}: {{ count }}&nbsp; {% endfor %}</td>
+      <td>{{ r.files_written|length }}</td>
+      <td>{{ r.flagged_tasks|length }}</td>
+    </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% else %}
+<p class="muted">No runs yet.</p>
+{% endif %}
+{% endblock %}
